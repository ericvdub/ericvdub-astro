---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Eric Vdub | Developer & Creator", description = "Eric Vdub - Developer & Creator. Building digital experiences." } = Astro.props;

const currentYear = new Date().getFullYear();
const navLinks = [
  { href: "/#home", label: "Home" },
  { href: "/#about", label: "About" },
  { href: "/#work", label: "Works" },
  { href: "/#contact", label: "Contact" },
];
---

<html lang="en" data-simple-page>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <div class="starfield">
      <div class="stars-layer stars-sm"></div>
      <div class="stars-layer stars-md"></div>
      <div class="stars-layer stars-lg"></div>
    </div>
    <div class="nebula"></div>

    <header class="sticky top-0 z-50 border-b border-white/5 bg-space-900/80 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
        <a href="/" class="group flex items-center gap-2 text-xl font-bold tracking-tight text-text-primary">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-accent text-space-900 text-sm font-extrabold transition-transform duration-300 group-hover:scale-110">
            EV
          </span>
          <span class="hidden sm:inline">ericvdub</span>
        </a>
        <div class="flex items-center gap-1">
          {navLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm font-medium text-text-secondary transition-colors duration-300 hover:text-text-primary"
            >
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main class="relative z-10">
      <slot />
    </main>

    <footer class="relative z-10 border-t border-white/5 px-6 py-6">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 sm:flex-row">
        <a href="/" class="flex items-center gap-2 text-sm font-bold text-text-primary">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-accent text-space-900 text-xs font-extrabold">
            EV
          </span>
          ericvdub
        </a>
        <nav class="flex items-center gap-5">
          {navLinks.map((link) => (
            <a href={link.href} class="text-xs text-text-secondary transition-colors hover:text-text-primary">
              {link.label}
            </a>
          ))}
        </nav>
        <p class="text-xs text-text-secondary/50">
          &copy; {currentYear} Eric Vdub
        </p>
      </div>
    </footer>
  </body>
</html>
