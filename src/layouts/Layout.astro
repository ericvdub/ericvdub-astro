---
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
}

const { title = "Eric Vdub | Developer & Creator" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Eric Vdub - Developer, Motorcycle Enthusiast, BJJ Practitioner. Building digital experiences." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <div class="starfield">
      <div class="stars-layer stars-sm"></div>
      <div class="stars-layer stars-md"></div>
      <div class="stars-layer stars-lg"></div>
    </div>
    <div class="nebula"></div>
    <Nav />
    <div id="fullpage-wrapper">
      <slot />
    </div>
    <script>
      // ── Fullpage Section Scroll Controller ──
      const wrapper = document.getElementById("fullpage-wrapper")!;
      const pages = Array.from(wrapper.querySelectorAll("section[id]"));
      const isMobile = window.matchMedia("(max-width: 767px)").matches;

      let currentIndex = 0;
      let isAnimating = false;
      const DURATION = 700;

      if (!isMobile) {
        // Position wrapper for transforms (desktop only)
        wrapper.style.transition = `transform ${DURATION}ms cubic-bezier(0.65, 0, 0.35, 1)`;
        wrapper.style.willChange = "transform";
      }

      function goToSection(index: number) {
        if (isMobile) return;
        if (index < 0 || index >= pages.length || index === currentIndex || isAnimating) return;
        isAnimating = true;

        // Instantly reset the section we're leaving
        hideSection(pages[currentIndex]);

        currentIndex = index;
        wrapper.style.transform = `translateY(-${currentIndex * 100}vh)`;
        updateNav();

        // Wait for the scroll to land, then animate content in
        setTimeout(() => {
          showSection(pages[currentIndex]);
          isAnimating = false;
        }, DURATION);
      }

      // ── Wheel handler (desktop only) ──
      let wheelAccum = 0;
      let wheelTimer: number;
      const WHEEL_THRESHOLD = 50;

      if (!isMobile) {
        window.addEventListener("wheel", (e) => {
          e.preventDefault();
          if (isAnimating) return;

          wheelAccum += e.deltaY;
          clearTimeout(wheelTimer);
          wheelTimer = window.setTimeout(() => { wheelAccum = 0; }, 200);

          if (Math.abs(wheelAccum) >= WHEEL_THRESHOLD) {
            goToSection(currentIndex + (wheelAccum > 0 ? 1 : -1));
            wheelAccum = 0;
          }
        }, { passive: false });

        // ── Keyboard handler (desktop only) ──
        window.addEventListener("keydown", (e) => {
          if (isAnimating) return;
          const tag = (e.target as HTMLElement).tagName;
          if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return;
          if (e.key === "ArrowDown" || e.key === "PageDown" || e.key === " ") {
            e.preventDefault();
            goToSection(currentIndex + 1);
          } else if (e.key === "ArrowUp" || e.key === "PageUp") {
            e.preventDefault();
            goToSection(currentIndex - 1);
          } else if (e.key === "Home") {
            e.preventDefault();
            goToSection(0);
          } else if (e.key === "End") {
            e.preventDefault();
            goToSection(pages.length - 1);
          }
        });
      }

      // ── Nav link clicks ──
      document.addEventListener("click", (e) => {
        const anchor = (e.target as Element).closest('a[href^="#"]');
        if (!anchor) return;
        const href = anchor.getAttribute("href");
        if (!href || href === "#") return;

        if (isMobile) {
          // Let browser handle smooth scroll on mobile
          e.preventDefault();
          const target = document.querySelector(href);
          if (target) target.scrollIntoView({ behavior: "smooth" });
          return;
        }

        const targetIndex = pages.findIndex(
          (p) => p.id === href.slice(1) || p.querySelector(href)
        );
        if (targetIndex === -1) return;

        e.preventDefault();
        goToSection(targetIndex);
      });

      // ── Active nav highlighting ──
      const navLinks = document.querySelectorAll("nav a[href^='#']");
      function updateNav() {
        if (isMobile) return;
        const currentPage = pages[currentIndex];
        const currentId = currentPage?.id;
        navLinks.forEach((link) => {
          link.classList.remove("text-accent", "after:scale-x-100");
          if (link.getAttribute("href") === `#${currentId}`) {
            link.classList.add("text-accent", "after:scale-x-100");
          }
        });
      }

      // ── Scroll-triggered animations (with reset) ──
      const STAGGER_DELAY = 120;

      function showSection(section: Element) {
        section.querySelectorAll(".stagger-card").forEach((card, i) => {
          setTimeout(() => card.classList.add("card-visible"), i * STAGGER_DELAY);
        });

        section.querySelectorAll(".divider-line").forEach((line) => {
          line.classList.add("line-visible");
        });
      }

      function hideSection(section: Element) {
        section.querySelectorAll(".stagger-card").forEach((card) => {
          card.classList.remove("card-visible");
        });

        section.querySelectorAll(".divider-line").forEach((line) => {
          line.classList.remove("line-visible");
        });
      }

      function triggerAnimations() {
        pages.forEach((page, i) => {
          if (i === currentIndex) {
            showSection(page);
          } else {
            hideSection(page);
          }
        });
      }

      if (isMobile) {
        const sectionObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const section = entry.target as HTMLElement;
              if (entry.isIntersecting) {
                showSection(section);
              } else {
                hideSection(section);
              }
            });
          },
          { threshold: 0.1 }
        );

        pages.forEach((page) => sectionObserver.observe(page));
      } else {
        triggerAnimations();
        updateNav();
      }
    </script>
  </body>
</html>
