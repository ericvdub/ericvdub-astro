function gaiMsg(role,text){
  var msgs=document.getElementById('gai-msgs');if(!msgs)return;
  if(role==='assistant'){
    var ty=document.createElement('div');ty.className='gai-typing';ty.innerHTML='<div class="tdot" style="background:var(--color-text-tertiary)"></div><div class="tdot" style="background:var(--color-text-tertiary)"></div><div class="tdot" style="background:var(--color-text-tertiary)"></div>';msgs.appendChild(ty);msgs.scrollTop=msgs.scrollHeight;
    setTimeout(function(){ty.remove();var m=document.createElement('div');m.className='gai-msg-ai';m.textContent=text;msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;},500);
  } else {
    var m=document.createElement('div');m.className='gai-msg-user';m.textContent=text;msgs.appendChild(m);msgs.scrollTop=msgs.scrollHeight;
