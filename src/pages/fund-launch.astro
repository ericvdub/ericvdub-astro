---
import SimpleLayout from "../layouts/SimpleLayout.astro";
---

<SimpleLayout
  title="Fund Launch AI — Fund Builder Prototype | Eric Vdub"
  description="Interactive UI prototype for Fund Launch AI's Fund Builder — an AI-powered platform that automates private fund formation."
>
  <!-- Hero -->
  <div class="mx-auto max-w-4xl px-6 pt-16 pb-8 lg:pt-24 text-center">
    <span
      class="inline-block rounded-full bg-accent/10 border border-accent/20 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-accent mb-6"
    >
      Design Proposal
    </span>
    <h1 class="text-4xl font-bold tracking-tight text-text-primary lg:text-5xl">
      Fund Launch AI
    </h1>
    <p class="mt-2 text-lg text-text-secondary font-medium">
      AI-Powered Fund Builder &mdash; Interactive Prototype
    </p>
    <p class="mt-8 max-w-2xl mx-auto text-sm leading-relaxed text-text-secondary">
      This prototype demonstrates how the Fund Builder's core form flow could
      feel&mdash;approachable enough for first-time fund managers, precise enough
      for institutional LPs, and intelligent enough to guide users through complex
      legal decisions with contextual AI at every step.
    </p>
  </div>

  <!-- Prototype -->
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-2 shadow-2xl sm:p-3">
      <iframe
        id="proto-frame"
        width="100%"
        height="700"
        style="border:none;border-radius:10px;background:#f8f9fa;"
        title="Fund Launch AI Fund Builder Prototype"
      ></iframe>
    </div>
    <p class="mt-4 text-center text-xs text-text-secondary/50">
      Interactive prototype&mdash;click through tabs, answer questions, and chat with
      the AI&nbsp;advisor. Best viewed on desktop.
    </p>
  </div>

  <!-- Design Decisions -->
  <div class="mx-auto max-w-4xl px-6 pt-8 pb-20">
    <h2 class="text-2xl font-bold text-text-primary text-center mb-10">
      Design Decisions
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-white/5 bg-white/[0.04] p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1.5">
          Folder tabs with floating progress bars
        </h3>
        <p class="text-xs leading-relaxed text-text-secondary">
          Each section's completion is visible as a thin bar above its tab.
          At-a-glance progress without cluttering the form workspace&mdash;users
          always know where they stand across all six stages.
        </p>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.04] p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1.5">
          Per-card contextual AI
        </h3>
        <p class="text-xs leading-relaxed text-text-secondary">
          Every question has an "Ask&nbsp;AI" chip that opens an inline chat with
          context about what the term means, how it affects documents, and
          suggested follow-ups. Help exactly where decisions happen.
        </p>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.04] p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1.5">
          Answered state with chat history
        </h3>
        <p class="text-xs leading-relaxed text-text-secondary">
          Completed questions collapse to show the answer and a preview of any AI
          conversation, with a link to reopen. Decisions feel permanent but always
          revisitable.
        </p>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.04] p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1.5">
          Sequential section unlocking
        </h3>
        <p class="text-xs leading-relaxed text-text-secondary">
          Tabs unlock as prior sections are completed. For a 147-point legal
          document pipeline, guided sequencing prevents missed dependencies and
          reduces cognitive load.
        </p>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.04] p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1.5">
          Automatic saves, no save button
        </h3>
        <p class="text-xs leading-relaxed text-text-secondary">
          Selections commit immediately. In a process this long, eliminating save
          friction keeps momentum and removes the anxiety of losing progress.
        </p>
      </div>
      <div class="rounded-xl border border-white/5 bg-white/[0.04] p-5">
        <h3 class="text-sm font-semibold text-text-primary mb-1.5">
          Dual-layer AI: per-card + global advisor
        </h3>
        <p class="text-xs leading-relaxed text-text-secondary">
          The per-card AI is scoped to the current question. The global AI Advisor
          panel handles fund-level strategy. Two levels of intelligence, each in
          the right context.
        </p>
      </div>
    </div>
  </div>

  <script is:inline>
    var cssVars = ':root{--font-sans:"Inter",-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;--color-text-primary:#111827;--color-text-secondary:#6b7280;--color-text-tertiary:#9ca3af;--color-background-primary:#ffffff;--color-background-secondary:#f9fafb;--color-background-tertiary:#f3f4f6;--color-border-primary:#d1d5db;--color-border-secondary:#e5e7eb;--color-border-tertiary:#f3f4f6;--color-border-success:#86efac;--border-radius-lg:12px;--border-radius-md:8px}';

    var proto = String.raw`
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans);color:var(--color-text-primary)}
.app{display:flex;height:640px;border-radius:var(--border-radius-lg);overflow:hidden;border:0.5px solid var(--color-border-tertiary);background:var(--color-background-tertiary)}

.sidebar{width:192px;flex-shrink:0;background:var(--color-background-primary);border-right:0.5px solid var(--color-border-tertiary);display:flex;flex-direction:column}
.sb-logo{padding:14px;border-bottom:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;gap:8px}
.logo-mark{width:24px;height:24px;background:#111827;border-radius:5px;display:flex;align-items:center;justify-content:center;color:#c9a84c;font-size:10px;font-weight:600;flex-shrink:0}
.sb-section{padding:12px 10px 4px;font-size:10px;color:var(--color-text-tertiary);letter-spacing:0.07em;text-transform:uppercase}
.nav-item{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:6px;margin:1px 6px;cursor:pointer;font-size:12.5px;color:var(--color-text-secondary);transition:background 0.12s,color 0.12s;user-select:none}
.nav-item:hover{background:var(--color-background-secondary);color:var(--color-text-primary)}
.nav-item.active{background:var(--color-background-secondary);color:var(--color-text-primary);font-weight:500}
.nav-item svg{opacity:0.45;flex-shrink:0;transition:opacity 0.12s}
.nav-item:hover svg,.nav-item.active svg{opacity:0.85}
.nav-badge{margin-left:auto;font-size:10px;padding:1px 6px;border-radius:10px;background:#faeeda;color:#854f0b;border:0.5px solid #fac775;line-height:1.6}
.sb-spacer{flex:1}
.sb-user{padding:10px 10px 12px;border-top:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;gap:8px}
.avatar{width:26px;height:26px;border-radius:50%;background:#e6f1fb;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:500;color:#185fa5;flex-shrink:0}

.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* TOP BAR */
.top-bar{padding:0 18px;border-bottom:0.5px solid var(--color-border-tertiary);background:var(--color-background-primary);display:flex;align-items:center;gap:14px;flex-shrink:0;height:48px}
.fund-title{font-size:13px;font-weight:500;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fund-type-badge{font-size:10px;padding:2px 8px;border-radius:10px;background:var(--color-background-secondary);border:0.5px solid var(--color-border-tertiary);color:var(--color-text-secondary);white-space:nowrap}
.circle-prog{position:relative;width:36px;height:36px;flex-shrink:0}
.circle-prog svg{transform:rotate(-90deg)}
.circle-prog .pct-label{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;color:var(--color-text-secondary)}
.ai-global-btn{display:flex;align-items:center;gap:5px;padding:5px 12px;border-radius:6px;font-size:11.5px;cursor:pointer;border:0.5px solid #85b7eb;background:#e6f1fb;color:#185fa5;transition:background 0.12s;font-family:var(--font-sans);white-space:nowrap}
.ai-global-btn:hover{background:#d0e6f7}
.ai-global-btn.active{background:#185fa5;border-color:#185fa5;color:#fff}

/* TABS */
.tab-region{background:var(--color-background-secondary);border-bottom:0.5px solid var(--color-border-tertiary);flex-shrink:0}
.tab-row{display:flex;padding:10px 16px 0;align-items:flex-end;gap:2px;overflow-x:auto}
.tab-row::-webkit-scrollbar{display:none}
.tab-wrap{display:flex;flex-direction:column;align-items:stretch;cursor:pointer;flex-shrink:0}
.tab-wrap.locked{cursor:not-allowed}
.prog-track{height:3px;border-radius:2px;margin:0 3px;background:var(--color-border-tertiary);overflow:hidden}
.prog-fill{height:100%;border-radius:2px;transition:width 0.5s cubic-bezier(0.4,0,0.2,1),background 0.3s}
.tab{padding:7px 13px;font-size:12px;border-radius:7px 7px 0 0;background:transparent;border:0.5px solid transparent;border-bottom:none;color:var(--color-text-tertiary);white-space:nowrap;margin-top:5px;display:flex;align-items:center;gap:5px;transition:background 0.15s,color 0.15s,border-color 0.15s;user-select:none}
.tab:hover:not(.tab-locked){background:var(--color-background-primary);color:var(--color-text-secondary)}
.tab.active{background:var(--color-background-primary);color:var(--color-text-primary);font-weight:500;border-color:var(--color-border-secondary)}
.tab.tab-locked{opacity:0.4;cursor:not-allowed}
.tab-done-dot{width:14px;height:14px;border-radius:50%;background:#eaf3de;border:0.5px solid #c0dd97;display:flex;align-items:center;justify-content:center;flex-shrink:0}

/* WORKSPACE */
.workspace{flex:1;display:flex;overflow:hidden;position:relative}
.form-scroll{flex:1;overflow-y:auto;padding:22px 24px 32px;min-width:0}
.sec-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px}
.sec-title{font-size:16px;font-weight:500}
.sec-meta{font-size:12px;color:var(--color-text-secondary);margin-top:3px}
.prog-pill{padding:3px 10px;border-radius:20px;background:var(--color-background-secondary);border:0.5px solid var(--color-border-tertiary);font-size:11px;color:var(--color-text-secondary);flex-shrink:0}
.prog-pill.done{background:#eaf3de;border-color:#c0dd97;color:#3b6d11}

/* QUESTION CARD */
.q-card{border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);margin-bottom:10px;background:var(--color-background-primary);transition:border-color 0.2s;animation:fadeUp 0.2s ease both;overflow:hidden}
.q-card.answered{border-color:var(--color-border-success)}
.q-card:hover{border-color:var(--color-border-secondary)}
.q-card-main{padding:16px 18px}
.q-num{font-size:10px;color:var(--color-text-tertiary);margin-bottom:5px;letter-spacing:0.06em;display:flex;align-items:center;justify-content:space-between}
.q-label{font-size:13.5px;font-weight:500;line-height:1.4;margin-bottom:3px}
.q-hint{font-size:11.5px;color:var(--color-text-secondary);margin-bottom:12px;line-height:1.5}
.q-done-badge{display:flex;align-items:center;gap:4px;font-size:10px;color:#3b6d11}
.q-done-badge svg{flex-shrink:0}

/* CHIPS */
.chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{padding:5px 12px;border-radius:20px;font-size:12px;border:0.5px solid var(--color-border-secondary);background:var(--color-background-secondary);cursor:pointer;color:var(--color-text-secondary);transition:all 0.12s;user-select:none}
.chip:hover{background:var(--color-background-tertiary);border-color:var(--color-border-primary);color:var(--color-text-primary)}
.chip:active{transform:scale(0.96)}
.chip.sel{background:#e6f1fb;border-color:#85b7eb;color:#185fa5;font-weight:500}
.chip.ai-chip{border-style:dashed;border-color:#85b7eb;color:#378add;background:transparent}
.chip.ai-chip:hover{background:#e6f1fb}
.chip.ai-chip.open{background:#e6f1fb;border-style:solid;border-color:#85b7eb;color:#185fa5}

/* ANSWERED SUMMARY */
.answer-summary{padding:10px 18px 14px;display:flex;align-items:flex-start;justify-content:space-between;gap:10px;border-top:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary)}
.ans-val{font-size:12.5px;color:var(--color-text-primary)}
.ans-ai-peek{font-size:11px;color:var(--color-text-secondary);font-style:italic;margin-top:2px;line-height:1.5;cursor:pointer}
.ans-ai-peek:hover{color:var(--color-text-primary)}
.peek-icon{display:inline-flex;align-items:center;gap:3px;color:#378add;font-size:10px;cursor:pointer;font-style:normal;margin-left:6px}
.peek-icon:hover{color:#185fa5}

/* PER-CARD AI CHAT */
.card-ai{border-top:0.5px solid #b5d4f4;background:#f3f8fd;animation:expandDown 0.2s ease}
.card-ai-head{padding:10px 16px 8px;display:flex;align-items:center;gap:6px}
.card-ai-label{font-size:11px;color:#185fa5;font-weight:500;flex:1}
.card-ai-close{font-size:14px;color:#378add;cursor:pointer;padding:2px 4px;line-height:1;background:none;border:none;font-family:var(--font-sans)}
.card-ai-summary{padding:0 16px 10px;font-size:12px;color:#0c447c;line-height:1.6;border-bottom:0.5px solid #b5d4f4}
.card-ai-msgs{padding:10px 16px;max-height:160px;overflow-y:auto;display:flex;flex-direction:column;gap:8px}
.cam-ai{background:#fff;border:0.5px solid #b5d4f4;border-radius:4px 10px 10px 10px;padding:8px 10px;font-size:12px;color:#185fa5;line-height:1.6;max-width:90%;animation:fadeUp 0.15s ease}
.cam-user{background:#e6f1fb;border-radius:10px 4px 10px 10px;padding:8px 10px;font-size:12px;color:#0c447c;line-height:1.6;max-width:90%;align-self:flex-end;animation:fadeUp 0.15s ease}
.cam-typing{background:#fff;border:0.5px solid #b5d4f4;border-radius:4px 10px 10px 10px;padding:10px 12px;display:flex;gap:4px;align-items:center}
.tdot{width:4px;height:4px;border-radius:50%;background:#85b7eb;animation:typeBounce 1.2s infinite}
.tdot:nth-child(2){animation-delay:.2s}
.tdot:nth-child(3){animation-delay:.4s}
.card-ai-suggestions{padding:6px 14px 8px;display:flex;flex-wrap:wrap;gap:5px}
.sug-chip{padding:4px 9px;font-size:11px;border-radius:4px;border:0.5px solid #85b7eb;cursor:pointer;background:#fff;color:#185fa5;transition:background 0.1s;font-family:var(--font-sans)}
.sug-chip:hover{background:#e6f1fb}
.card-ai-input{padding:8px 12px;border-top:0.5px solid #b5d4f4;display:flex;gap:6px}
.cai-inp{flex:1;font-size:12px;padding:6px 10px;border-radius:var(--border-radius-md);border:0.5px solid #85b7eb;background:#fff;color:var(--color-text-primary);outline:none;font-family:var(--font-sans);transition:border-color 0.15s}
.cai-inp:focus{border-color:#378add}
.cai-send{padding:6px 10px;border-radius:var(--border-radius-md);border:0.5px solid #85b7eb;background:#e6f1fb;cursor:pointer;font-size:12px;color:#185fa5;font-family:var(--font-sans);transition:background 0.1s}
.cai-send:hover{background:#d0e6f7}

/* OPEN-ENDED CARD */
.oe-inp{width:100%;padding:9px 12px;border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-secondary);background:var(--color-background-secondary);font-size:12.5px;color:var(--color-text-primary);outline:none;font-family:var(--font-sans);transition:border-color 0.15s;resize:none;line-height:1.6}
.oe-inp:focus{border-color:var(--color-border-primary)}
.oe-actions{display:flex;align-items:center;gap:6px;margin-top:8px}
.oe-confirm{padding:6px 14px;border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-secondary);background:var(--color-background-secondary);font-size:12px;cursor:pointer;color:var(--color-text-secondary);font-family:var(--font-sans);transition:background 0.12s}
.oe-confirm:hover{background:var(--color-background-tertiary)}
.oe-confirm.primary{border-color:#85b7eb;background:#e6f1fb;color:#185fa5}
.oe-confirm.primary:hover{background:#d0e6f7}

/* CONTINUE BTN */
.continue-wrap{margin-top:20px;display:flex;justify-content:flex-end}
.continue-btn{padding:9px 22px;border-radius:var(--border-radius-md);border:0.5px solid #85b7eb;background:#e6f1fb;font-size:12.5px;cursor:pointer;color:#185fa5;font-weight:500;font-family:var(--font-sans);transition:background 0.12s,transform 0.1s}
.continue-btn:hover{background:#d0e6f7}
.continue-btn:active{transform:scale(0.97)}
.continue-btn:disabled{opacity:0.35;cursor:not-allowed}

/* COMPLETED VIEW */
.completed-field{display:grid;grid-template-columns:130px 1fr;gap:8px;padding:8px 0;border-bottom:0.5px solid var(--color-border-tertiary)}
.completed-field:last-child{border-bottom:none}
.cf-label{font-size:12px;color:var(--color-text-secondary)}
.cf-val{font-size:12px}

/* LOCK */
.lock-state{border:0.5px dashed var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:52px 24px;text-align:center;animation:fadeUp 0.2s ease}
.lock-circle{width:38px;height:38px;border-radius:50%;background:var(--color-background-secondary);border:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;font-size:15px}
.lock-sub{font-size:12px;color:var(--color-text-secondary);line-height:1.6;max-width:230px;margin:6px auto 14px}
.lock-cta{padding:6px 16px;border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-secondary);background:var(--color-background-secondary);font-size:12px;cursor:pointer;color:var(--color-text-secondary);font-family:var(--font-sans)}

/* GLOBAL AI PANEL */
.global-ai{width:0;flex-shrink:0;background:var(--color-background-primary);border-left:0.5px solid transparent;display:flex;flex-direction:column;overflow:hidden;transition:width 0.25s cubic-bezier(0.4,0,0.2,1),border-color 0.25s}
.global-ai.open{width:252px;border-left-color:var(--color-border-tertiary)}
.gai-head{padding:13px 13px 10px;border-bottom:0.5px solid var(--color-border-tertiary);flex-shrink:0}
.gai-title{font-size:13px;font-weight:500;display:flex;align-items:center;gap:6px}
.gai-dot{width:6px;height:6px;border-radius:50%;background:#378add;flex-shrink:0;animation:pulse 2s infinite}
.gai-sub{font-size:11px;color:var(--color-text-tertiary);margin-top:2px}
.gai-msgs{flex:1;overflow-y:auto;padding:10px 12px}
.gai-msg-ai{background:var(--color-background-secondary);border-radius:4px 10px 10px 10px;padding:8px 10px;font-size:12px;line-height:1.6;color:var(--color-text-secondary);margin-bottom:8px;animation:fadeUp 0.15s ease}
.gai-msg-user{background:#e6f1fb;border-radius:10px 4px 10px 10px;padding:8px 10px;font-size:12px;color:#0c447c;text-align:right;line-height:1.6;margin-bottom:8px;animation:fadeUp 0.15s ease}
.gai-typing{background:var(--color-background-secondary);border-radius:4px 10px 10px 10px;padding:10px 14px;display:flex;gap:4px;margin-bottom:8px}
.gai-quick{padding:8px 12px;border-top:0.5px solid var(--color-border-tertiary);display:flex;flex-wrap:wrap;gap:4px;flex-shrink:0}
.gai-qchip{padding:4px 8px;font-size:11px;border-radius:4px;border:0.5px solid var(--color-border-secondary);cursor:pointer;background:var(--color-background-secondary);color:var(--color-text-secondary);transition:background 0.1s;font-family:var(--font-sans)}
.gai-qchip:hover{background:var(--color-background-tertiary)}
.gai-input-row{padding:8px 10px;border-top:0.5px solid var(--color-border-tertiary);display:flex;gap:6px;flex-shrink:0}
.gai-inp{flex:1;font-size:12px;padding:7px 10px;border-radius:var(--border-radius-md);border:0.5px solid var(--color-border-secondary);background:var(--color-background-secondary);color:var(--color-text-primary);font-family:var(--font-sans);outline:none}
.gai-inp:focus{border-color:var(--color-border-primary)}
.gai-send{padding:7px 10px;border-radius:var(--border-radius-md);border:0.5px solid #85b7eb;background:#e6f1fb;cursor:pointer;font-size:13px;color:#185fa5;font-family:var(--font-sans)}
.gai-send:hover{background:#d0e6f7}

@keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
@keyframes expandDown{from{opacity:0;max-height:0}to{opacity:1;max-height:600px}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
@keyframes typeBounce{0%,60%,100%{transform:translateY(0)}30%{transform:translateY(-3px)}}
@keyframes popIn{from{opacity:0;transform:scale(.5)}to{opacity:1;transform:scale(1)}}
</style>

<div class="app">

<!-- SIDEBAR -->
<div class="sidebar">
  <div class="sb-logo">
    <div class="logo-mark">FL</div>
    <div style="font-size:12px;font-weight:500">Fund Launch</div>
  </div>
  <div class="sb-section">Workspace</div>
  <div class="nav-item active" onclick="setNav(this)">
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="1.5" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.3"/><rect x="9" y="1.5" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.3"/><rect x="1.5" y="9" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.3"/><rect x="9" y="9" width="5.5" height="5.5" rx="1.2" stroke="currentColor" stroke-width="1.3"/></svg>
    My Funds<span class="nav-badge">2</span>
  </div>
  <div class="nav-item" onclick="setNav(this)">
