}

function sendGAI(){var inp=document.getElementById('gai-inp');var q=inp.value.trim();if(!q)return;gaiMsg('user',q);inp.value='';setTimeout(function(){gaiMsg('assistant',getGAI(q));},50);}
function gaiQuick(q){if(!gaiOpen)toggleGlobalAI();setTimeout(function(){gaiMsg('user',q);setTimeout(function(){gaiMsg('assistant',getGAI(q));},50);},gaiOpen?0:280);}

function setNav(el){document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active');});el.classList.add('active');}

