        <div class="gai-msg-ai">Hi Jordan — ask me anything about your fund structure, legal terms, or document requirements.</div>
      </div>
      <div class="gai-quick">
        <div class="gai-qchip" onclick="gaiQuick('What is standard carry?')">Standard carry?</div>
        <div class="gai-qchip" onclick="gaiQuick('Explain hurdle rate')">Hurdle rate?</div>
        <div class="gai-qchip" onclick="gaiQuick('What documents will I get?')">Output docs?</div>
      </div>
      <div class="gai-input-row">
        <input class="gai-inp" id="gai-inp" placeholder="Ask anything..." onkeydown="if(event.key==='Enter')sendGAI()"/>
