<script>
var currentTab=2, gaiOpen=false;
var cardAI={};
var cardAnswers={fee:'',carry:'',hurdle:'',minimum:''};
var cardHistory={};

var TABS=[
  {label:'Fund Identity',   prog:100,done:true, locked:false},
  {label:'Legal Structure', prog:100,done:true, locked:false},
  {label:'Fund Economics',  prog:0,  done:false,locked:false},
  {label:'Investor Terms',  prog:0,  done:false,locked:true, need:'Fund Economics'},
  {label:'Compliance',      prog:0,  done:false,locked:true, need:'Investor Terms'},
  {label:'Documents',       prog:0,  done:false,locked:true, need:'All stages'},
];

var CARD_AI_DATA={
  fee:{
    summary:'Management fees are charged annually on your committed capital. They fund operations while you deploy. Too high repels LPs; too low may underfund your team.',
    suggestions:['What do first-time VC funds typically charge?','How does step-down work post-investment?','Will this appear in my PPM?']
  },
  carry:{
    summary:'Carried interest is your profit share — the primary way fund managers get paid for performance. It only activates after LPs get their capital back plus any preferred return.',
    suggestions:['Why is 20% the standard?','What is a carry waterfall?','How does carry interact with my hurdle rate?']
  },
  hurdle:{
    summary:'The preferred return (hurdle rate) is an annual threshold LPs receive before you earn any carry. It aligns your incentives with investor returns.',
    suggestions:['Do I need a preferred return?','What is a catch-up clause?','How does 8% compare to other funds?']
  },
  minimum:{
    summary:'Your LP minimum sets the floor for investor commitments and shapes your investor pipeline. Higher minimums mean fewer, larger checks and a different fundraising strategy.',
    suggestions:['What minimum is typical for VC?','How does minimum affect accreditation?','Can I have tiered minimums?']
  }
};

var GAI_ANSWERS={
  carry:'20% is the market standard — first-time managers rarely deviate. Carry activates only after LPs recover capital plus any preferred return.',
  hurdle:'An 8% preferred return means LPs earn 8% annually before you take carry. Institutional LPs strongly prefer this structure.',
  fee:'2% on committed capital during deployment is standard. Most managers step down to 1.5% on invested capital afterward.',
  docs:'For a Venture Capital fund you\'ll receive: LPA (Limited Partnership Agreement), PPM (Private Placement Memorandum), Subscription Agreement, and Form D filing.',
  default:'Based on your VC fund structure, focus on getting the 2/20/8 terms right first — these anchor your entire LPA. What specifically can I clarify?'
};

function getGAI(q){var l=q.toLowerCase();if(l.includes('carry')||l.includes('carried'))return GAI_ANSWERS.carry;if(l.includes('hurdle')||l.includes('preferred'))return GAI_ANSWERS.hurdle;if(l.includes('fee'))return GAI_ANSWERS.fee;if(l.includes('doc')||l.includes('output')||l.includes('get'))return GAI_ANSWERS.docs;return GAI_ANSWERS.default;}

function getCardAI(cid,q){
  var d=CARD_AI_DATA[cid];if(!d)return'Great question about this topic. The answer will shape your fund documents — I can help clarify any aspect.';
  var l=q.toLowerCase();
  if(l.includes('standard')||l.includes('typical'))return'For a first-time VC fund, the 2% management fee and 20% carried interest are industry standards that signal professionalism to institutional LPs.';
  if(l.includes('step')||l.includes('step-down'))return'A step-down reduces your management fee from committed to invested capital after the investment period ends — typically 3–5 years. This shows alignment with LPs.';
  if(l.includes('ppm')||l.includes('document'))return'Yes — this term appears prominently in your PPM and LPA. Fund Launch will auto-populate the correct legal language based on what you enter here.';
  if(l.includes('waterfall'))return'A carry waterfall defines the order of distributions: first LPs get capital back, then preferred return, then GP catch-up (if any), then 80/20 split.';
  if(l.includes('catch-up'))return'A GP catch-up clause lets you quickly earn carry once LPs hit their hurdle — typically structured as 100% to GP until you\'ve caught up to 20% of total profits.';
  if(l.includes('tiered'))return'Tiered minimums are possible — some funds offer $100K for individuals and $250K for institutions. This must be clearly stated in your subscription documents.';
  if(l.includes('accreditation'))return'Your LP minimum doesn\'t directly determine accreditation requirements, but higher minimums ($250K+) naturally filter for sophisticated investors and reduce compliance burden.';
  return'That\'s a great question about this term. In short: '+d.summary+' Want me to go deeper on any aspect?';
}

function countAns(){return(cardAnswers.fee?1:0)+(cardAnswers.carry?1:0)+(cardAnswers.hurdle?1:0)+(cardAnswers.minimum?1:0);}

function overallPct(){
  var done=2;
  var partial=countAns()/4;
  return Math.round(((done+partial)/6)*100);
}

function updateCircle(){
  var pct=overallPct();
  var circ=document.getElementById('circ-fill');
  var lbl=document.getElementById('pct-label');
  if(!circ)return;
  var circumference=2*Math.PI*14;
  circ.setAttribute('stroke-dasharray',circumference.toFixed(1));
  circ.setAttribute('stroke-dashoffset',(circumference*(1-pct/100)).toFixed(1));
  if(lbl)lbl.textContent=pct+'%';
  TABS[2].prog=Math.round((countAns()/4)*100);
  var pf=document.getElementById('pf2');
  if(pf){pf.style.width=TABS[2].prog+'%';pf.style.background=TABS[2].prog===100?'#639922':TABS[2].prog>0?'#ba7517':'transparent';}
}

function buildTabs(){
  var row=document.getElementById('tab-row');row.innerHTML='';
  TABS.forEach(function(t,i){
    var w=document.createElement('div');
    w.className='tab-wrap'+(t.locked?' locked':'');
    w.onclick=function(){t.locked?clickLocked(t):switchTab(i);};
    var pw=Math.max(74,t.label.length*6.5+20);
    var pc=t.prog===100?'#639922':t.prog>0?'#ba7517':'transparent';
    var ti='';
    if(t.done)ti='<div class="tab-done-dot"><svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1.5 4l2 2 3-3" stroke="#3b6d11" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>';
    else if(t.locked)ti='<svg width="10" height="10" viewBox="0 0 12 12" fill="none"><rect x="2.5" y="5" width="7" height="5.5" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M4 5V3.5a2 2 0 114 0V5" stroke="currentColor" stroke-width="1.2"/></svg>';
    w.innerHTML='<div class="prog-track" style="width:'+pw+'px"><div class="prog-fill" id="pf'+i+'" style="width:'+t.prog+'%;background:'+pc+'"></div></div>'
      +'<div class="tab'+(i===currentTab?' active':'')+(t.locked?' tab-locked':'')+'" id="tab'+i+'">'+ti+t.label+'</div>';
    row.appendChild(w);
  });
}

function switchTab(i){
  currentTab=i;
  document.querySelectorAll('.tab').forEach(function(t,j){t.classList.toggle('active',j===i);});
  renderContent();
  document.getElementById('form-scroll').scrollTop=0;
}

function clickLocked(t){
  gaiMsg('assistant','This section unlocks after you complete '+t.need+'. You\'re '+countAns()+'/4 done on Fund Economics.');
  if(!gaiOpen)toggleGlobalAI();
}

function renderContent(){
  var area=document.getElementById('form-area');
  if(currentTab===0||currentTab===1){
    var f=currentTab===0?[['Fund name','Apex Capital Partners I'],['Fund type','Venture Capital'],['Investment thesis','Early-stage B2B SaaS disrupting legacy enterprise']]:[['Domicile','Delaware (Recommended)'],['GP entity','Apex Capital GP LLC'],['Principals','Jordan Kim, Casey Reeves']];
    var t=currentTab===0?'Fund Identity':'Legal Structure';
    var m=currentTab===0?'Name, type, and investment thesis':'Entity, domicile, and GP/LP structure';
    var h='<div class="sec-header"><div><div class="sec-title">'+t+'</div><div class="sec-meta">'+m+'</div></div><span class="prog-pill done">&#x2713; Complete</span></div>';
    h+='<div class="q-card answered"><div class="q-card-main">';
    f.forEach(function(fi){h+='<div class="completed-field"><div class="cf-label">'+fi[0]+'</div><div class="cf-val">'+fi[1]+'</div></div>';});
    h+='</div></div>';
    h+='<div class="continue-wrap"><button class="continue-btn" onclick="switchTab('+(currentTab+1)+')">Continue &#x2192;</button></div>';
    area.innerHTML=h;return;
  }
  if(currentTab===2){
    var n=countAns();
    var h='<div class="sec-header"><div><div class="sec-title">Fund Economics</div><div class="sec-meta">Management fee, carried interest, hurdle rate, and LP minimum</div></div><span class="prog-pill" id="ppill">'+n+'/4 answered</span></div>';
    h+=buildMCCard('fee','01','Management fee','Charged annually on committed capital. A key term in your LPA and PPM.',['1.5% annually','2.0% annually','2.5% annually'],0);
    h+=buildMCCard('carry','02','Carried interest','Your share of profits after LPs receive their preferred return.',['15%','20% (standard)','25%'],1);
    h+=buildMCCard('hurdle','03','Preferred return (hurdle rate)','LPs earn this annual return before carry activates.',['No preferred return','6% preferred','8% preferred (standard)'],2);
    h+=buildOECard('minimum','04','Minimum LP investment','Sets your investor pipeline expectations. Typical VC range: $100K–$500K.',3);
    h+='<div class="continue-wrap"><button class="continue-btn" id="cont-btn" '+(n<4?'disabled':'')+' onclick="switchTab(3)">Continue &#x2192;</button></div>';
    area.innerHTML=h;
    restoreCardAI();return;
  }
  var ti=TABS[currentTab];
  area.innerHTML='<div class="lock-state"><div class="lock-circle">&#x1F512;</div><div style="font-size:14px;font-weight:500">'+ti.label+' is locked</div><div class="lock-sub">Complete '+ti.need+' to unlock this section.</div><button class="lock-cta" onclick="switchTab(2)">&#x2190; Back to Fund Economics</button></div>';
}

function buildMCCard(cid,num,label,hint,opts,delay){
  var ans=cardAnswers[cid];
  var isOpen=cardAI[cid];
  var hist=cardHistory[cid];
  var d='animation-delay:'+(delay*0.05)+'s';

  if(ans&&!isOpen){
    var h='<div class="q-card answered" style="'+d+'">';
    h+='<div class="q-card-main">';
    h+='<div class="q-num"><span>'+num+'</span><div class="q-done-badge"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="#3b6d11" stroke-width="1"/><path d="M3 5l1.5 1.5L7 3.5" stroke="#3b6d11" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg> Answered</div></div>';
    h+='<div class="q-label">'+label+'</div>';
    h+='</div>';
    h+='<div class="answer-summary">';
    h+='<div><div class="ans-val">'+ans+'</div>';
    if(hist&&hist.length>0){h+='<div class="ans-ai-peek">'+hist[hist.length-1].text.substring(0,80)+'…<span class="peek-icon" onclick="openCardAI(\''+cid+'\')">&#x25C8; view chat</span></div>';}
    h+='</div>';
    h+='<div class="chip ai-chip" onclick="openCardAI(\''+cid+'\')" style="font-size:11px;padding:4px 10px">&#x25C8; AI</div>';
    h+='</div>';
    h+='</div>';
    return h;
  }

  var h='<div class="q-card'+(ans?' answered':'')+'" style="'+d+'" id="card-'+cid+'">';
  h+='<div class="q-card-main">';
  h+='<div class="q-num">'+num+'</div>';
  h+='<div class="q-label">'+label+'</div>';
  h+='<div class="q-hint">'+hint+'</div>';
  h+='<div class="chips">';
  opts.forEach(function(o){h+='<div class="chip'+(ans===o?' sel':'')+'" onclick="pickMC(\''+cid+'\',\''+o+'\')">'+o+'</div>';});
  h+='<div class="chip ai-chip'+(isOpen?' open':'')+'" onclick="toggleCardAI(\''+cid+'\')" id="aichip-'+cid+'">&#x25C8; Ask AI</div>';
  h+='</div></div>';
  if(isOpen){h+=buildCardAIPanel(cid);}
  h+='</div>';
  return h;
}

function buildOECard(cid,num,label,hint,delay){
  var ans=cardAnswers[cid];
  var isOpen=cardAI[cid];
  var hist=cardHistory[cid];
  var d='animation-delay:'+(delay*0.05)+'s';

  if(ans&&!isOpen){
    var h='<div class="q-card answered" style="'+d+'">';
    h+='<div class="q-card-main">';
    h+='<div class="q-num"><span>'+num+'</span><div class="q-done-badge"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="#3b6d11" stroke-width="1"/><path d="M3 5l1.5 1.5L7 3.5" stroke="#3b6d11" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg> Answered</div></div>';
    h+='<div class="q-label">'+label+'</div>';
    h+='</div>';
    h+='<div class="answer-summary">';
    h+='<div><div class="ans-val">'+ans+'</div>';
    if(hist&&hist.length>0){h+='<div class="ans-ai-peek">'+hist[hist.length-1].text.substring(0,80)+'…<span class="peek-icon" onclick="openCardAI(\''+cid+'\')">&#x25C8; view chat</span></div>';}
    h+='</div>';
    h+='<div class="chip ai-chip" onclick="openCardAI(\''+cid+'\')" style="font-size:11px;padding:4px 10px">&#x25C8; AI</div>';
    h+='</div>';
    h+='</div>';
    return h;
  }

  var h='<div class="q-card'+(ans?' answered':'')+'" style="'+d+'" id="card-'+cid+'">';
  h+='<div class="q-card-main">';
  h+='<div class="q-num">'+num+'</div>';
  h+='<div class="q-label">'+label+'</div>';
  h+='<div class="q-hint">'+hint+'</div>';
  h+='<textarea class="oe-inp" rows="2" id="inp-'+cid+'" placeholder="Type your answer…" oninput="typeOE(\''+cid+'\',this.value)">'+ans+'</textarea>';
  h+='<div class="oe-actions">';
  h+='<button class="oe-confirm primary" onclick="confirmOE(\''+cid+'\')">Confirm answer</button>';
  h+='<div class="chip ai-chip'+(isOpen?' open':'')+'" onclick="toggleCardAI(\''+cid+'\')" style="font-size:12px" id="aichip-'+cid+'">&#x25C8; Ask AI</div>';
  h+='</div>';
  h+='</div>';
  if(isOpen){h+=buildCardAIPanel(cid);}
  h+='</div>';
  return h;
}

function buildCardAIPanel(cid){
  var d=CARD_AI_DATA[cid];
  var hist=cardHistory[cid]||[];
  var h='<div class="card-ai" id="cai-'+cid+'">';
  h+='<div class="card-ai-head"><div style="width:16px;height:16px;border-radius:3px;background:#185fa5;display:flex;align-items:center;justify-content:center;flex-shrink:0"><svg width="9" height="9" viewBox="0 0 10 10" fill="none"><circle cx="5" cy="5" r="4" stroke="white" stroke-width="1"/><path d="M5 3v2.5l1.5 1" stroke="white" stroke-width="1" stroke-linecap="round"/></svg></div><div class="card-ai-label">AI Advisor — '+CARD_AI_DATA[cid]?CARD_AI_DATA[cid].summary.split(' ').slice(0,4).join(' ')+'…':'this question'+'</div><button class="card-ai-close" onclick="closeCardAI(\''+cid+'\')">&#xd7;</button></div>';
  h+='<div class="card-ai-summary">'+d.summary+'</div>';
  h+='<div class="card-ai-msgs" id="cmsgs-'+cid+'">';
  if(hist.length===0){h+='<div class="cam-ai">How can I help you with this? Try one of the suggested questions below or ask anything.</div>';}
  else{hist.forEach(function(m){h+='<div class="'+(m.role==='user'?'cam-user':'cam-ai')+'">'+m.text+'</div>';});}
  h+='</div>';
  h+='<div class="card-ai-suggestions" id="csug-'+cid+'">';
  d.suggestions.forEach(function(s){h+='<div class="sug-chip" onclick="cardSugAsk(\''+cid+'\',\''+s.replace(/'/g,"\\'")+'\')">'+s+'</div>';});
  h+='</div>';
  h+='<div class="card-ai-input"><input class="cai-inp" id="cinp-'+cid+'" placeholder="Ask about this question…" onkeydown="if(event.key===\'Enter\')sendCardAI(\''+cid+'\')"/><button class="cai-send" onclick="sendCardAI(\''+cid+'\')">&#x2191;</button></div>';
  h+='</div>';
  return h;
}

function restoreCardAI(){
  Object.keys(cardAI).forEach(function(cid){
    if(cardAI[cid]&&!cardAnswers[cid]){
      var el=document.getElementById('card-'+cid);
      if(el&&!el.querySelector('.card-ai')){el.insertAdjacentHTML('beforeend',buildCardAIPanel(cid));}
    }
  });
}

function toggleCardAI(cid){
  cardAI[cid]=!cardAI[cid];
  renderContent();
  setTimeout(function(){var el=document.getElementById('cmsgs-'+cid);if(el)el.scrollTop=el.scrollHeight;},50);
}

function openCardAI(cid){cardAI[cid]=true;renderContent();setTimeout(function(){var el=document.getElementById('cmsgs-'+cid);if(el)el.scrollTop=el.scrollHeight;},50);}
function closeCardAI(cid){cardAI[cid]=false;renderContent();}

function cardSugAsk(cid,q){
  if(!cardHistory[cid])cardHistory[cid]=[];
  cardHistory[cid].push({role:'user',text:q});
  var msgs=document.getElementById('cmsgs-'+cid);
  if(msgs){var um=document.createElement('div');um.className='cam-user';um.textContent=q;msgs.appendChild(um);
    var ty=document.createElement('div');ty.className='cam-typing';ty.innerHTML='<div class="tdot"></div><div class="tdot"></div><div class="tdot"></div>';msgs.appendChild(ty);msgs.scrollTop=msgs.scrollHeight;
    setTimeout(function(){ty.remove();var r=getCardAI(cid,q);cardHistory[cid].push({role:'assistant',text:r});var am=document.createElement('div');am.className='cam-ai';am.textContent=r;msgs.appendChild(am);msgs.scrollTop=msgs.scrollHeight;},500);
  }
  var sug=document.getElementById('csug-'+cid);if(sug)sug.style.display='none';
}

function sendCardAI(cid){
  var inp=document.getElementById('cinp-'+cid);if(!inp)return;
  var q=inp.value.trim();if(!q)return;
  inp.value='';
  cardSugAsk(cid,q);
}

function pickMC(cid,val){
  cardAnswers[cid]=val;
  cardAI[cid]=false;
  updateCircle();
  renderContent();
  var pp=document.getElementById('ppill');if(pp)pp.textContent=countAns()+'/4 answered';
  var cb=document.getElementById('cont-btn');if(cb)cb.disabled=(countAns()<4);
}

var oeTemp={};
function typeOE(cid,val){oeTemp[cid]=val;}
function confirmOE(cid){
  var v=oeTemp[cid]||(document.getElementById('inp-'+cid)||{}).value||'';
  if(!v.trim())return;
