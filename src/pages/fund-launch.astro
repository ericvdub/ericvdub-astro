        <circle cx="18" cy="18" r="14" fill="none" stroke="var(--color-border-tertiary)" stroke-width="3"/>
        <circle id="circ-fill" cx="18" cy="18" r="14" fill="none" stroke="#378add" stroke-width="3" stroke-dasharray="88" stroke-dashoffset="62" stroke-linecap="round" style="transition:stroke-dashoffset 0.6s cubic-bezier(0.4,0,0.2,1)"/>
      </svg>
      <div class="pct-label" id="pct-label">30%</div>
