---
import SimpleLayout from "../layouts/SimpleLayout.astro";
---

<SimpleLayout title="Client Intake Form | Eric Vdub" description="Tell me about your business so I can build your perfect website.">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <span class="mb-3 inline-block text-sm font-semibold uppercase tracking-widest text-accent">New Project</span>
      <h1 class="mb-4 text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl">Client Intake Form</h1>
      <p class="mx-auto max-w-xl text-text-secondary">
        Fill out as much as you can — don't worry if you're not sure about everything. We'll figure it out together.
      </p>
    </div>

    <form id="intake-form" class="space-y-8" novalidate>

      <!-- Section 1: Your Information -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Your Information</legend>
        <div class="space-y-4">
          <div>
            <label for="contact_name" class="mb-1.5 block text-sm font-medium text-text-secondary">Your name <span class="text-accent">*</span></label>
            <input type="text" id="contact_name" name="contact_name" required data-trim class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="John Smith" />
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="contact_email" class="mb-1.5 block text-sm font-medium text-text-secondary">Your email <span class="text-accent">*</span></label>
              <input type="email" id="contact_email" name="contact_email" required data-trim class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="john@example.com" />
            </div>
            <div>
              <label for="contact_phone" class="mb-1.5 block text-sm font-medium text-text-secondary">Your phone</label>
              <input type="tel" id="contact_phone" name="contact_phone" data-phone class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="(555) 123-4567" />
            </div>
          </div>
        </div>
      </fieldset>

      <!-- Section 2: Business Information -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Business Information</legend>
        <div class="space-y-4">
          <div>
            <label for="business_name" class="mb-1.5 block text-sm font-medium text-text-secondary">Business name <span class="text-accent">*</span></label>
            <input type="text" id="business_name" name="business_name" required data-trim class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Acme Corp" />
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="industry" class="mb-1.5 block text-sm font-medium text-text-secondary">Industry / business type</label>
              <input type="text" id="industry" name="industry" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="e.g. Restaurant, Law Firm, Monument Company" />
            </div>
            <div>
              <label for="founded_year" class="mb-1.5 block text-sm font-medium text-text-secondary">Founded year</label>
              <div class="year-picker relative" id="year-picker">
                <input type="text" id="founded_year" name="founded_year" readonly class="w-full cursor-pointer rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Select year..." />
                <div id="year-picker-dropdown" class="hidden absolute z-50 mt-2 w-full rounded-xl border border-white/10 bg-space-800 p-3 shadow-xl shadow-black/40">
                  <div class="flex items-center justify-between mb-2">
                    <button type="button" id="yp-prev" class="rounded-lg p-1.5 text-text-secondary hover:bg-white/10 hover:text-text-primary transition-colors" aria-label="Previous years">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
                    </button>
                    <span id="yp-range" class="text-sm font-semibold text-text-primary"></span>
                    <button type="button" id="yp-next" class="rounded-lg p-1.5 text-text-secondary hover:bg-white/10 hover:text-text-primary transition-colors" aria-label="Next years">
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                    </button>
                  </div>
                  <div id="yp-grid" class="grid grid-cols-3 gap-1.5"></div>
                </div>
              </div>
            </div>
          </div>
          <div>
            <label for="tagline" class="mb-1.5 block text-sm font-medium text-text-secondary">Tagline / motto</label>
            <input type="text" id="tagline" name="tagline" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Your business slogan" />
          </div>
          <div>
            <label for="business_description" class="mb-1.5 block text-sm font-medium text-text-secondary">Brief business description</label>
            <textarea id="business_description" name="business_description" rows="3" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="What do you do? Who do you serve?"></textarea>
          </div>
        </div>
      </fieldset>

      <!-- Section 3: Contact Details -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Business Contact Details</legend>
        <div class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="business_phone" class="mb-1.5 block text-sm font-medium text-text-secondary">Business phone</label>
              <input type="tel" id="business_phone" name="business_phone" data-phone class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="(555) 123-4567" />
            </div>
            <div>
              <label for="business_email" class="mb-1.5 block text-sm font-medium text-text-secondary">Business email</label>
              <input type="email" id="business_email" name="business_email" data-trim class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="info@yourbusiness.com" />
            </div>
          </div>
          <div>
            <label for="street_address" class="mb-1.5 block text-sm font-medium text-text-secondary">Street address</label>
            <input type="text" id="street_address" name="street_address" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="123 Main Street" />
          </div>
          <div class="grid gap-4 sm:grid-cols-3">
            <div>
              <label for="city" class="mb-1.5 block text-sm font-medium text-text-secondary">City</label>
              <input type="text" id="city" name="city" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Springfield" />
            </div>
            <div>
              <label for="state" class="mb-1.5 block text-sm font-medium text-text-secondary">State</label>
              <input type="text" id="state" name="state" maxlength="2" pattern="[A-Za-z]{2}" title="Enter a 2-letter state abbreviation" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent uppercase" placeholder="IL" />
            </div>
            <div>
              <label for="zip" class="mb-1.5 block text-sm font-medium text-text-secondary">ZIP</label>
              <input type="text" id="zip" name="zip" maxlength="10" inputmode="numeric" data-zip data-trim class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="84065" />
            </div>
          </div>
          <div>
            <label for="google_maps_url" class="mb-1.5 block text-sm font-medium text-text-secondary">Google Maps URL or address</label>
            <input type="text" id="google_maps_url" name="google_maps_url" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Paste a Google Maps link or your full address" />
          </div>

          <!-- Business Hours (repeatable) -->
          <div>
            <label class="mb-1.5 block text-sm font-medium text-text-secondary">Business hours</label>
            <div id="hours-list" class="space-y-2">
              <div class="hours-row flex items-center gap-2">
                <input type="text" name="hours_days[]" class="w-1/2 rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="e.g. Mon-Fri" />
                <input type="text" name="hours_times[]" class="w-1/2 rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="e.g. 9am - 5pm" />
              </div>
            </div>
            <template id="hours-template">
              <div class="hours-row flex items-center gap-2">
                <input type="text" name="hours_days[]" class="w-1/2 rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="e.g. Sat-Sun" />
                <input type="text" name="hours_times[]" class="w-1/2 rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="e.g. 10am - 2pm" />
                <button type="button" class="remove-row shrink-0 rounded-lg p-2 text-text-secondary hover:bg-red-500/10 hover:text-red-400 transition-colors" aria-label="Remove">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
              </div>
            </template>
            <button type="button" id="add-hours" class="mt-2 text-sm font-medium text-accent hover:text-accent-light transition-colors">+ Add hours</button>
          </div>
        </div>
      </fieldset>

      <!-- Section 4: Services & Areas -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Services & Areas</legend>
        <div class="space-y-4">
          <div>
            <label for="services" class="mb-1.5 block text-sm font-medium text-text-secondary">Services offered</label>
            <textarea id="services" name="services" rows="3" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="List your main services or products, one per line"></textarea>
          </div>
          <div>
            <label for="service_areas" class="mb-1.5 block text-sm font-medium text-text-secondary">Service areas / regions</label>
            <textarea id="service_areas" name="service_areas" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Where do you operate? e.g. Greater Chicago Area, Nationwide, etc."></textarea>
          </div>
        </div>
      </fieldset>

      <!-- Section 5: Brand & Design -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Brand & Design</legend>
        <div class="space-y-4">
          <div>
            <label for="brand_color" class="mb-1.5 block text-sm font-medium text-text-secondary">Primary brand color</label>
            <div class="flex items-center gap-3">
              <input type="color" id="brand_color_picker" value="#e08a1e" class="h-10 w-10 cursor-pointer rounded-lg border border-white/10 bg-transparent" />
              <input type="text" id="brand_color" name="brand_color" pattern="#[0-9a-fA-F]{6}" title="Enter a hex color (e.g. #e08a1e)" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="#e08a1e" />
            </div>
          </div>
          <div>
            <label class="mb-1.5 block text-sm font-medium text-text-secondary">Logo</label>
            <p class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-text-secondary">
              Upload your logo to a shared Google Drive folder &mdash; see <a href="/next-steps#photos" class="text-accent hover:text-accent-light transition-colors">Next Steps</a> for instructions.
            </p>
          </div>
          <div>
            <label for="design_inspiration" class="mb-1.5 block text-sm font-medium text-text-secondary">Websites you like / design inspiration</label>
            <textarea id="design_inspiration" name="design_inspiration" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Share URLs of websites you like or describe the style you're going for"></textarea>
          </div>
          <div>
            <label for="design_style" class="mb-1.5 block text-sm font-medium text-text-secondary">Design style preference</label>
            <select id="design_style" name="design_style" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent">
              <option value="" class="bg-space-900">Select a style...</option>
              <option value="Modern & Clean" class="bg-space-900">Modern & Clean</option>
              <option value="Classic & Traditional" class="bg-space-900">Classic & Traditional</option>
              <option value="Bold & Dynamic" class="bg-space-900">Bold & Dynamic</option>
              <option value="Minimal & Simple" class="bg-space-900">Minimal & Simple</option>
              <option value="Not Sure" class="bg-space-900">Not Sure</option>
            </select>
          </div>
        </div>
      </fieldset>

      <!-- Section 6: Website Content -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Website Content</legend>
        <div class="space-y-4">
          <div>
            <label for="hero_headline" class="mb-1.5 block text-sm font-medium text-text-secondary">Hero headline</label>
            <input type="text" id="hero_headline" name="hero_headline" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="The big text visitors see first" />
          </div>
          <div>
            <label for="hero_subheadline" class="mb-1.5 block text-sm font-medium text-text-secondary">Hero subheadline</label>
            <textarea id="hero_subheadline" name="hero_subheadline" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="A supporting line below the headline"></textarea>
          </div>
          <div>
            <label for="about_story" class="mb-1.5 block text-sm font-medium text-text-secondary">About / company story</label>
            <textarea id="about_story" name="about_story" rows="4" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="A few paragraphs about your business — history, mission, values"></textarea>
          </div>

          <!-- Testimonials (repeatable) -->
          <div>
            <label class="mb-1.5 block text-sm font-medium text-text-secondary">Testimonials</label>
            <div id="testimonials-list" class="space-y-3">
              <div class="testimonial-row rounded-xl border border-white/10 bg-white/5 p-4 space-y-2">
                <div class="grid gap-2 sm:grid-cols-2">
                  <input type="text" name="testimonial_name[]" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Customer name" />
                  <input type="text" name="testimonial_location[]" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Location (e.g. Chicago, IL)" />
                </div>
                <textarea name="testimonial_text[]" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="What did they say about your business?"></textarea>
              </div>
            </div>
            <template id="testimonial-template">
              <div class="testimonial-row rounded-xl border border-white/10 bg-white/5 p-4 space-y-2">
                <div class="flex items-start justify-between gap-2">
                  <div class="grid flex-1 gap-2 sm:grid-cols-2">
                    <input type="text" name="testimonial_name[]" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Customer name" />
                    <input type="text" name="testimonial_location[]" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Location" />
                  </div>
                  <button type="button" class="remove-row shrink-0 rounded-lg p-2 text-text-secondary hover:bg-red-500/10 hover:text-red-400 transition-colors" aria-label="Remove">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </div>
                <textarea name="testimonial_text[]" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="What did they say?"></textarea>
              </div>
            </template>
            <button type="button" id="add-testimonial" class="mt-2 text-sm font-medium text-accent hover:text-accent-light transition-colors">+ Add testimonial</button>
          </div>

          <!-- FAQ (repeatable) -->
          <div>
            <label class="mb-1.5 block text-sm font-medium text-text-secondary">FAQ items</label>
            <div id="faq-list" class="space-y-3">
              <div class="faq-row rounded-xl border border-white/10 bg-white/5 p-4 space-y-2">
                <input type="text" name="faq_question[]" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Question" />
                <textarea name="faq_answer[]" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Answer"></textarea>
              </div>
            </div>
            <template id="faq-template">
              <div class="faq-row rounded-xl border border-white/10 bg-white/5 p-4 space-y-2">
                <div class="flex items-center gap-2">
                  <input type="text" name="faq_question[]" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Question" />
                  <button type="button" class="remove-row shrink-0 rounded-lg p-2 text-text-secondary hover:bg-red-500/10 hover:text-red-400 transition-colors" aria-label="Remove">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  </button>
                </div>
                <textarea name="faq_answer[]" rows="2" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-sm text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Answer"></textarea>
              </div>
            </template>
            <button type="button" id="add-faq" class="mt-2 text-sm font-medium text-accent hover:text-accent-light transition-colors">+ Add FAQ</button>
          </div>
        </div>
      </fieldset>

      <!-- Section 7: Existing Accounts & Access -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Existing Accounts & Access</legend>
        <div class="space-y-4">
          <div>
            <label class="mb-1.5 block text-sm font-medium text-text-secondary">Current website URL(s), if any</label>
            <div id="websites-list" class="space-y-2">
              <div class="website-row flex items-center gap-2">
                <input type="text" name="current_website[]" data-website class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="yourbusiness.com" />
              </div>
            </div>
            <template id="website-template">
              <div class="website-row flex items-center gap-2">
                <input type="text" name="current_website[]" data-website class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="another-site.com" />
                <button type="button" class="remove-row shrink-0 rounded-lg p-2 text-text-secondary hover:bg-red-500/10 hover:text-red-400 transition-colors" aria-label="Remove">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
              </div>
            </template>
            <button type="button" id="add-website" class="mt-2 text-sm font-medium text-accent hover:text-accent-light transition-colors">+ Add another website</button>
          </div>
          <div>
            <label for="domain_registrar" class="mb-1.5 block text-sm font-medium text-text-secondary">Domain registrar</label>
            <select id="domain_registrar" name="domain_registrar" class="w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent">
              <option value="" class="bg-space-900">Select your registrar...</option>
              <option value="GoDaddy" class="bg-space-900">GoDaddy</option>
              <option value="Namecheap" class="bg-space-900">Namecheap</option>
              <option value="Cloudflare" class="bg-space-900">Cloudflare</option>
              <option value="Google Domains / Squarespace" class="bg-space-900">Google Domains / Squarespace</option>
              <option value="I don't know" class="bg-space-900">I don't know</option>
              <option value="I don't have one" class="bg-space-900">I don't have one</option>
            </select>
          </div>
          <div>
            <span class="mb-2 block text-sm font-medium text-text-secondary">Do you have a Google Business Profile?</span>
            <div class="flex flex-wrap gap-2" id="gbp-group">
              <label class="gbp-option cursor-pointer rounded-full border border-white/10 px-4 py-1.5 text-sm text-text-secondary transition-all hover:border-accent hover:text-accent">
                <input type="radio" name="google_business_profile" value="Yes" class="hidden" />
                Yes
              </label>
              <label class="gbp-option cursor-pointer rounded-full border border-white/10 px-4 py-1.5 text-sm text-text-secondary transition-all hover:border-accent hover:text-accent">
                <input type="radio" name="google_business_profile" value="No" class="hidden" />
                No
              </label>
              <label class="gbp-option cursor-pointer rounded-full border border-white/10 px-4 py-1.5 text-sm text-text-secondary transition-all hover:border-accent hover:text-accent">
                <input type="radio" name="google_business_profile" value="I don't know" class="hidden" />
                I don't know
              </label>
            </div>
          </div>
        </div>
      </fieldset>

      <!-- Section 8: Additional Notes -->
      <fieldset class="rounded-2xl border border-white/5 bg-surface p-6 sm:p-8">
        <legend class="mb-4 text-lg font-bold text-text-primary">Additional Notes</legend>
        <div>
          <label for="additional_notes" class="mb-1.5 block text-sm font-medium text-text-secondary">Anything else you'd like me to know?</label>
          <textarea id="additional_notes" name="additional_notes" rows="4" class="w-full resize-none rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-text-primary placeholder-text-secondary/50 outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent" placeholder="Special requests, timeline, budget, questions..."></textarea>
        </div>
      </fieldset>

      <!-- Submit -->
      <div class="text-center">
        <button
          type="submit"
          id="submit-btn"
          class="group inline-flex w-full max-w-md items-center justify-center rounded-xl bg-accent px-8 py-3 font-semibold text-space-900 shadow-lg shadow-accent/25 transition-all duration-300 hover:bg-accent-light hover:shadow-accent/40 hover:-translate-y-0.5"
        >
          <span id="btn-text" class="flex items-center gap-2">
            Submit Intake Form
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </span>
          <span id="btn-loading" class="hidden flex items-center gap-2">
            Sending...
          </span>
        </button>
      </div>

    </form>

    <div id="form-success" class="hidden rounded-2xl border border-green-500/20 bg-green-500/10 p-8 sm:p-12 text-center">
      <div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-full bg-green-500/20">
        <svg class="h-8 w-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h2 class="text-2xl font-bold text-green-400">Form Submitted Successfully!</h2>
      <p class="mt-3 text-text-secondary">Thank you! I'll review your information and be in touch soon.</p>
      <p class="mt-2 text-sm text-text-secondary">In the meantime, check out the next steps to see what else you can do to prepare.</p>
      <a href="/next-steps" class="mt-6 inline-flex items-center gap-2 rounded-xl bg-accent px-8 py-3 font-semibold text-space-900 shadow-lg shadow-accent/25 transition-all duration-300 hover:bg-accent-light hover:shadow-accent/40 hover:-translate-y-0.5">
        View Next Steps
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>

    <div id="form-error" class="hidden rounded-2xl border border-red-500/20 bg-red-500/10 p-6 text-center">
      <p class="text-lg font-semibold text-red-400">Something went wrong</p>
      <p class="mt-2 text-sm text-red-400/80">Please try again or email me directly at <a href="mailto:eric@ericvdub.com" class="underline hover:text-red-300">eric@ericvdub.com</a></p>
      <button type="button" id="retry-btn" class="mt-4 rounded-xl border border-red-500/30 px-6 py-2 text-sm font-medium text-red-400 transition-colors hover:bg-red-500/10">
        Try Again
      </button>
    </div>
  </div>
</SimpleLayout>

<script>
  // ── Trim on blur ──
  document.addEventListener("focusout", (e) => {
    const target = e.target as HTMLInputElement;
    if (target.hasAttribute?.("data-trim") && target.value) {
      target.value = target.value.trim();
    }
  });

  // ── Year picker ──
  (() => {
    const MIN_YEAR = 1900;
    const MAX_YEAR = 2026;
    const PER_PAGE = 12; // 4 rows x 3 cols
    const input = document.getElementById("founded_year") as HTMLInputElement;
    const dropdown = document.getElementById("year-picker-dropdown")!;
    const grid = document.getElementById("yp-grid")!;
    const rangeLabel = document.getElementById("yp-range")!;
    const prevBtn = document.getElementById("yp-prev")!;
    const nextBtn = document.getElementById("yp-next")!;

    let pageStart = MAX_YEAR - PER_PAGE + 1; // start showing most recent years

    function render() {
      grid.innerHTML = "";
      const end = pageStart + PER_PAGE - 1;
      rangeLabel.textContent = `${pageStart} – ${Math.min(end, MAX_YEAR)}`;

      prevBtn.classList.toggle("invisible", pageStart <= MIN_YEAR);
      nextBtn.classList.toggle("invisible", end >= MAX_YEAR);

      for (let y = pageStart; y <= Math.min(end, MAX_YEAR); y++) {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.textContent = String(y);
        const isSelected = input.value === String(y);
        btn.className = `rounded-lg px-2 py-2 text-sm transition-colors ${
          isSelected
            ? "bg-accent text-space-900 font-semibold"
            : "text-text-secondary hover:bg-white/10 hover:text-text-primary"
        }`;
        btn.addEventListener("click", () => {
          input.value = String(y);
          dropdown.classList.add("hidden");
          clearFieldError(input);
        });
        grid.appendChild(btn);
      }
    }

    prevBtn.addEventListener("click", () => {
      pageStart = Math.max(MIN_YEAR, pageStart - PER_PAGE);
      render();
    });

    nextBtn.addEventListener("click", () => {
      pageStart = Math.min(MAX_YEAR - PER_PAGE + 1, pageStart + PER_PAGE);
      render();
    });

    input.addEventListener("click", () => {
      // If a value is selected, center the page on it
      if (input.value) {
        const val = parseInt(input.value);
        pageStart = Math.max(MIN_YEAR, Math.min(val - Math.floor(PER_PAGE / 2), MAX_YEAR - PER_PAGE + 1));
      }
      render();
      dropdown.classList.toggle("hidden");
    });

    // Close on outside click
    document.addEventListener("click", (e) => {
      if (!(e.target as Element).closest("#year-picker")) {
        dropdown.classList.add("hidden");
      }
    });
  })();

  // ── ZIP validation ──
  const ZIP_RE = /^\d{5}(-\d{4})?$/;
  document.querySelectorAll<HTMLInputElement>("[data-zip]").forEach((input) => {
    function validate() {
      const val = input.value.trim();
      if (!val) { input.setCustomValidity(""); return; }
      input.setCustomValidity(ZIP_RE.test(val) ? "" : "Enter a 5-digit ZIP code (e.g. 84065)");
    }
    input.addEventListener("input", validate);
    input.addEventListener("blur", validate);
  });

  // ── Color picker sync ──
  const colorPicker = document.getElementById("brand_color_picker") as HTMLInputElement;
  const colorText = document.getElementById("brand_color") as HTMLInputElement;

  colorPicker.addEventListener("input", () => {
    colorText.value = colorPicker.value;
  });
  colorText.addEventListener("input", () => {
    if (/^#[0-9a-fA-F]{6}$/.test(colorText.value)) {
      colorPicker.value = colorText.value;
    }
  });

  // ── Phone auto-format: (555) 123-4567 ──
  function formatPhone(value: string): string {
    const digits = value.replace(/\D/g, "").slice(0, 10);
    if (digits.length <= 3) return digits;
    if (digits.length <= 6) return `(${digits.slice(0, 3)}) ${digits.slice(3)}`;
    return `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`;
  }

  function validatePhone(input: HTMLInputElement) {
    const digits = input.value.replace(/\D/g, "");
    if (digits.length === 0) {
      input.setCustomValidity("");
    } else if (digits.length < 10) {
      input.setCustomValidity("Enter a 10-digit phone number");
    } else {
      input.setCustomValidity("");
    }
  }

  document.querySelectorAll<HTMLInputElement>("[data-phone]").forEach((input) => {
    input.addEventListener("input", () => {
      const pos = input.selectionStart ?? 0;
      const before = input.value.length;
      input.value = formatPhone(input.value);
      const after = input.value.length;
      const newPos = Math.max(0, pos + (after - before));
      input.setSelectionRange(newPos, newPos);
      validatePhone(input);
    });
    input.addEventListener("blur", () => validatePhone(input));
  });

  // ── Website URL custom validation ──
  const VALID_TLD_RE = /\.[a-z]{2,}$/i;

  function validateWebsite(input: HTMLInputElement) {
    const val = input.value.trim();
    if (!val) {
      input.setCustomValidity("");
      return;
    }
    // Strip protocol if present for the TLD check
    const domain = val.replace(/^https?:\/\//, "").split("/")[0];
    if (!VALID_TLD_RE.test(domain)) {
      input.setCustomValidity("Enter a valid domain (e.g. yourbusiness.com)");
    } else {
      input.setCustomValidity("");
    }
  }

  document.getElementById("intake-form")!.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    if (target.hasAttribute("data-website")) validateWebsite(target);
  });
  document.getElementById("intake-form")!.addEventListener("focusout", (e) => {
    const target = e.target as HTMLInputElement;
    if (target.hasAttribute("data-website")) validateWebsite(target);
  });

  // ── Radio group styling ──
  document.querySelectorAll(".gbp-option").forEach((label) => {
    label.querySelector("input")!.addEventListener("change", () => {
      document.querySelectorAll(".gbp-option").forEach((l) => {
        l.classList.remove("bg-accent", "text-space-900", "border-accent");
      });
      label.classList.add("bg-accent", "text-space-900", "border-accent");
    });
  });

  // ── Repeatable field helpers ──
  function setupRepeatable(addBtnId: string, templateId: string, listId: string) {
    const addBtn = document.getElementById(addBtnId)!;
    const template = document.getElementById(templateId) as HTMLTemplateElement;
    const list = document.getElementById(listId)!;

    addBtn.addEventListener("click", () => {
      const clone = template.content.cloneNode(true) as DocumentFragment;
      clone.querySelector(".remove-row")?.addEventListener("click", (e) => {
        const btn = e.currentTarget as HTMLElement;
        // Walk up to the direct child of the list container
        let row = btn.parentElement;
        while (row && row.parentElement !== list) row = row.parentElement;
        row?.remove();
      });
      list.appendChild(clone);
    });
  }

  setupRepeatable("add-hours", "hours-template", "hours-list");
  setupRepeatable("add-testimonial", "testimonial-template", "testimonials-list");
  setupRepeatable("add-faq", "faq-template", "faq-list");
  setupRepeatable("add-website", "website-template", "websites-list");

  // ── Validation helpers ──
  function showFieldError(field: HTMLElement, message: string) {
    const wrapper = field.closest("div")!;
    wrapper.classList.add("field-error");
    if (!wrapper.querySelector(".field-error-msg")) {
      const msg = document.createElement("p");
      msg.className = "field-error-msg";
      msg.textContent = message;
      field.insertAdjacentElement("afterend", msg);
    }
  }

  function clearFieldError(field: HTMLElement) {
    const wrapper = field.closest("div")!;
    wrapper.classList.remove("field-error");
    wrapper.querySelector(".field-error-msg")?.remove();
  }

  // Track which fields have been touched
  const touched = new WeakSet<Element>();

  // Clear errors as the user types (if field becomes valid)
  document.getElementById("intake-form")!.addEventListener("input", (e) => {
    const target = e.target as HTMLInputElement;
    if (target.matches("input, textarea, select")) {
      touched.add(target);
      if (target.checkValidity()) {
        clearFieldError(target);
      }
    }
  });

  // Validate on blur for touched fields
  document.getElementById("intake-form")!.addEventListener("focusout", (e) => {
    const target = e.target as HTMLInputElement;
    if (!target.matches("input, textarea, select")) return;
    touched.add(target);
    if (!target.value && !target.required) return; // skip empty optional fields
    if (!target.checkValidity()) {
      showFieldError(target, target.title || target.validationMessage);
    } else {
      clearFieldError(target);
    }
  });

  function validateForm(form: HTMLFormElement): boolean {
    let firstError: HTMLElement | null = null;

    // Clear all previous errors
    form.querySelectorAll(".field-error").forEach((el) => el.classList.remove("field-error"));
    form.querySelectorAll(".field-error-msg").forEach((el) => el.remove());

    // Check all inputs with native validation
    const fields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>("input, textarea, select");
    for (const field of fields) {
      if (!field.checkValidity()) {
        const message = field.title || field.validationMessage;
        showFieldError(field, message);
        if (!firstError) firstError = field;
      }
    }

    if (firstError) {
      firstError.scrollIntoView({ behavior: "smooth", block: "center" });
      firstError.focus({ preventScroll: true });
      return false;
    }
    return true;
  }

  // ── Form submission ──
  const form = document.getElementById("intake-form") as HTMLFormElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!validateForm(form)) return;

    const btnText = document.getElementById("btn-text")!;
    const btnLoading = document.getElementById("btn-loading")!;
    const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
    const successMsg = document.getElementById("form-success")!;
    const errorMsg = document.getElementById("form-error")!;

    submitBtn.disabled = true;
    btnText.classList.add("hidden");
    btnLoading.classList.remove("hidden");
    successMsg.classList.add("hidden");
    errorMsg.classList.add("hidden");

    // Gather form data
    const formData = new FormData(form);
    const data: Record<string, unknown> = {};

    // Single-value fields
    for (const [key, value] of formData.entries()) {
      if (!key.endsWith("[]")) {
        data[key] = value;
      }
    }

    // Current websites (repeatable)
    const websites = formData.getAll("current_website[]").filter(Boolean);
    if (websites.length) data.current_websites = websites;

    // Business hours (repeatable)
    const hoursDays = formData.getAll("hours_days[]");
    const hoursTimes = formData.getAll("hours_times[]");
    data.business_hours = hoursDays.map((day, i) => ({
      days: day,
      times: hoursTimes[i] || "",
    })).filter((h) => h.days || h.times);

    // Testimonials (repeatable)
    const tNames = formData.getAll("testimonial_name[]");
    const tLocations = formData.getAll("testimonial_location[]");
    const tTexts = formData.getAll("testimonial_text[]");
    data.testimonials = tNames.map((name, i) => ({
      name,
      location: tLocations[i] || "",
      text: tTexts[i] || "",
    })).filter((t) => t.name || t.text);

    // FAQ (repeatable)
    const faqQuestions = formData.getAll("faq_question[]");
    const faqAnswers = formData.getAll("faq_answer[]");
    data.faq = faqQuestions.map((q, i) => ({
      question: q,
      answer: faqAnswers[i] || "",
    })).filter((f) => f.question || f.answer);

    try {
      const response = await fetch("https://submit-form.com/C5mWZBcjc", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        form.classList.add("hidden");
        successMsg.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      } else {
        form.classList.add("hidden");
        errorMsg.classList.remove("hidden");
        window.scrollTo({ top: 0, behavior: "smooth" });
      }
    } catch {
      form.classList.add("hidden");
      errorMsg.classList.remove("hidden");
      window.scrollTo({ top: 0, behavior: "smooth" });
    } finally {
      submitBtn.disabled = false;
      btnText.classList.remove("hidden");
      btnLoading.classList.add("hidden");
    }
  });

  // ── Retry button ──
  document.getElementById("retry-btn")!.addEventListener("click", () => {
    document.getElementById("form-error")!.classList.add("hidden");
    form.classList.remove("hidden");
  });
</script>
