<section id="home" class="relative flex min-h-screen items-center justify-center overflow-hidden">
  <!-- Warm ambient glow behind hero -->
  <div class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 h-[600px] w-[600px] rounded-full bg-amber-500/[0.04] blur-[150px]"></div>

  <div class="hero-inner relative z-10 mx-auto flex w-full max-w-6xl flex-col items-center px-6 lg:flex-row lg:gap-12">
    <!-- Text content -->
    <div class="hero-text order-2 text-center lg:order-1 lg:w-1/2 lg:text-left">
      <div class="stagger-card hero-badge inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/5 px-4 py-1.5 text-sm text-accent backdrop-blur-sm">
        <span class="inline-block h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
        Available for projects
      </div>

      <h1 class="stagger-card hero-heading font-extrabold leading-[1.1] tracking-tight">
        Welcome to
        <span class="block bg-gradient-to-r from-amber-warm via-accent to-amber-bright bg-clip-text text-transparent">
          (my) Space
        </span>
      </h1>

      <p class="stagger-card hero-subtext max-w-lg leading-relaxed text-text-secondary lg:mx-0 mx-auto">
        Developer. Creator. Rider. I build digital experiences and chase passions that keep me sharp.
      </p>

      <div class="stagger-card hero-cta flex flex-col items-center gap-3 sm:flex-row lg:justify-start">
        <a
          href="#contact"
          class="btn-shimmer group inline-flex items-center gap-2 rounded-xl bg-accent px-7 py-3 font-semibold text-space-900 shadow-lg shadow-accent/20 transition-all duration-300 hover:bg-accent-light hover:shadow-accent/30 hover:-translate-y-0.5"
        >
          Contact Me
          <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#work"
          class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-7 py-3 font-semibold text-text-primary backdrop-blur-sm transition-all duration-300 hover:border-accent/30 hover:bg-white/10 hover:-translate-y-0.5"
        >
          View My Work
        </a>
      </div>
    </div>

    <!-- Space egg astronaut image -->
    <div class="stagger-card order-1 relative flex justify-center lg:order-2 lg:w-1/2">
      <!-- Warm glow behind astronaut -->
      <div class="hero-glow absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/10 blur-[80px]"></div>
      <img
        src="/space-egg.webp"
        alt="Astronaut hatching from an egg on the moon"
        class="hero-img hero-float relative z-10 max-w-full drop-shadow-[0_0_50px_rgba(224,138,30,0.25)]"
        loading="eager"
      />
    </div>
  </div>

  <!-- Scroll indicator (hidden on very short viewports) -->
  <div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 hero-scroll-hint">
    <a href="#about" class="flex flex-col items-center gap-2 text-text-secondary/40 transition-colors hover:text-accent/70">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
